{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md", "CLAUDE.md"],
  "watcher": {
    "ignore": [".git/**", ".worktrees/**", "node_modules/**", "**/*.encrypted"]
  },
  "formatter": {
    "prettier": {
      "disabled": true
    },
    "shfmt": {
      "command": ["shfmt", "-w", "-i", "2", "$FILE"],
      "extensions": [".sh"]
    }
  },
  "permission": {
    "read": {
      "*.encrypted": "deny",
      "*.encrypted.*": "deny"
    },
    "edit": {
      "*.encrypted": "deny",
      "*.encrypted.*": "deny"
    }
  },
  "lsp": false
}
